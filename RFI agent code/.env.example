# RFI Agent — Environment Variables
# Copy this to .env and fill in your values
# .env is gitignored — credentials never leave your machine

# ─── LLM Provider (required) ────────────────────────────────────
# Supported: "anthropic", "openai", "azure_openai"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
LLM_API_KEY=your-llm-api-key-here
# LLM_BASE_URL=          # Optional: custom endpoint (for OpenAI-compatible APIs, Ollama, LM Studio, etc.)

# ─── Azure AI Search (required for v2 retrieval) ────────────────
AZURE_SEARCH_ENDPOINT=https://your-service.search.windows.net
AZURE_SEARCH_API_KEY=your-search-admin-key-here
AZURE_SEARCH_QUESTION_INDEX=rfi-questions
AZURE_SEARCH_KNOWLEDGE_INDEX=rfi-knowledge

# ─── Azure OpenAI — Embeddings (required for vector search) ─────
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_API_KEY=your-openai-key-here
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-02-01

# ─── Optional ───────────────────────────────────────────────────
# AZURE_SEARCH_SEMANTIC_CONFIG=my-semantic-config   # Enables semantic ranker (requires Standard tier)
# AZURE_SEARCH_SCORING_PROFILE=client-boost         # Enables client-name boost scoring
